set(CMAKE_SYSTEM_NAME Linux)

set(PI_TOOLCHAIN_PREFIX "$ENV{PI_TOOLCHAIN_PREFIX}")
if(NOT PI_TOOLCHAIN_PREFIX)
    set(PI_TOOLCHAIN_PREFIX aarch64-linux-gnu)
endif()

if(PI_TOOLCHAIN_PREFIX MATCHES "^aarch64")
    set(CMAKE_SYSTEM_PROCESSOR aarch64)
elseif(PI_TOOLCHAIN_PREFIX MATCHES "^arm")
    set(CMAKE_SYSTEM_PROCESSOR arm)
else()
    set(CMAKE_SYSTEM_PROCESSOR unknown)
endif()

set(CMAKE_C_COMPILER "${PI_TOOLCHAIN_PREFIX}-gcc")
set(CMAKE_CXX_COMPILER "${PI_TOOLCHAIN_PREFIX}-g++")
set(CMAKE_AR "${PI_TOOLCHAIN_PREFIX}-gcc-ar")
set(CMAKE_RANLIB "${PI_TOOLCHAIN_PREFIX}-gcc-ranlib")
set(CMAKE_STRIP "${PI_TOOLCHAIN_PREFIX}-strip")
set(CMAKE_TRY_COMPILE_TARGET_TYPE STATIC_LIBRARY)

if(DEFINED ENV{PI_SYSROOT} AND NOT "$ENV{PI_SYSROOT}" STREQUAL "")
    set(CMAKE_SYSROOT "$ENV{PI_SYSROOT}")
    set(CMAKE_FIND_ROOT_PATH "$ENV{PI_SYSROOT}")
    set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
    set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
    set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
    set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
endif()
